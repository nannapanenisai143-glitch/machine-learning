import pandas as pd
from sklearn.linear_model import LinearRegression

data = pd.DataFrame({
    'Month':[1,2,3,4,5,6],
    'Sales':[100,120,140,160,180,200]
})

X = data[['Month']]
y = data['Sales']

model = LinearRegression()
model.fit(X,y)

pred = model.predict([[7]])

print("Predicted Sales:", pred[0])
