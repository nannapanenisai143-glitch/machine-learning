import pandas as pd
from sklearn.linear_model import LinearRegression

data = pd.DataFrame({
    'RAM':[4,6,8,12],
    'Price':[15000,20000,25000,35000]
})

X = data[['RAM']]
y = data['Price']

model = LinearRegression()
model.fit(X,y)

pred = model.predict([[10]])

print("Predicted Mobile Price:", pred[0])
